# Sky-Eye 环境配置
# 复制此文件为 .env 并填入实际值

# 数据库
DATABASE_URL=sqlite:///./sky_eye.db

# 服务
HOST=127.0.0.1
PORT=8000
DEBUG=True

# 空间搜索引擎 API（可选，配置后自动回填资产）
FOFA_EMAIL=
FOFA_KEY=
HUNTER_API_KEY=
QUAKE_TOKEN=

# DNS 历史 / CDN 穿透（可选）
SECURITYTRAILS_API_KEY=

# HTTP 代理（可选，调试用）
HTTP_PROXY=
SOCKS5_PROXY=

# 扫描参数
PORT_SCAN_BANNER=True
WAF_EVASION=True
ENABLE_EXPLOIT=False
